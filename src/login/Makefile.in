
COMMON_H = $(shell ls ../common/*.hpp)
COMMON_AR = ../common/obj/common.a
COMMON_INCLUDE = -I../common/

RA_INCLUDE = -I../

LIBCONFIG_H = $(shell ls ../../3rdparty/libconfig/*.h)
LIBCONFIG_AR = ../../3rdparty/libconfig/obj/libconfig.a
LIBCONFIG_INCLUDE = -I../../3rdparty/libconfig

LOGIN_OBJ = $(shell ls *.cpp | sed -e "s/\.cpp/\.o/g")
LOGIN_DIR_OBJ = $(LOGIN_OBJ:%=obj/%)

# SATHENA: external consumer sources — a consumer build passes CUSTOM_SRC_DIR=<abs dir> (+
# optional CUSTOM_DEFINES). <dir>/common and <dir>/login *.cpp are compiled and linked
# DIRECTLY into this binary (direct objects, NOT into common.a — archives dead-strip
# self-registering seam consumers), and -I<dir> is placed FIRST so the consumer's custom/
# shadows the src/custom stubs. Empty default = pure vanilla build.
CUSTOM_INCLUDE = $(if $(CUSTOM_SRC_DIR),-I$(CUSTOM_SRC_DIR))
CUSTOM_SRC = $(if $(CUSTOM_SRC_DIR),$(wildcard $(CUSTOM_SRC_DIR)/common/*.cpp) $(wildcard $(CUSTOM_SRC_DIR)/login/*.cpp))
CUSTOM_DIR_OBJ = $(patsubst $(CUSTOM_SRC_DIR)/%.cpp,obj/custom/%.o,$(CUSTOM_SRC))

LOGIN_H = $(shell ls *.hpp)

RAPIDYAML_OBJ = $(shell find ../../3rdparty/rapidyaml/ -type f -name "*.cpp" | sed -e "s/\.cpp/\.o/g" )
RAPIDYAML_DIR_OBJ = $(RAPIDYAML_OBJ:%=obj/%)
RAPIDYAML_AR = ../../3rdparty/rapidyaml/obj/ryml.a
RAPIDYAML_H = $(shell find ../../3rdparty/rapidyaml/ -type f -name "*.h*")
RAPIDYAML_INCLUDE = -I../../3rdparty/rapidyaml/src -I../../3rdparty/rapidyaml/ext/c4core/src

HAVE_MYSQL=@HAVE_MYSQL@
ifeq ($(HAVE_MYSQL),yes)
	SERVER_DEPENDS=login-server
else
	SERVER_DEPENDS=needs_mysql
endif
ALL_DEPENDS=server

@SET_MAKE@

#####################################################################
.PHONY :all server clean help

all: $(ALL_DEPENDS)

server: $(SERVER_DEPENDS)

clean:
	@echo "	CLEAN	login"
	@rm -rf *.o obj ../../@OLOG@@EXEEXT@

help:
	@echo "possible targets are 'server' 'all' 'clean' 'help'"
	@echo "'server'    - login server"
	@echo "'all'       - builds all above targets"
	@echo "'clean'     - cleans builds and objects"
	@echo "'help'      - outputs this message"

#####################################################################

needs_mysql:
	@echo "MySQL not found or disabled by the configure script"
	@exit 1

# object directories

obj:
	@echo "	MKDIR	obj"
	@-mkdir obj

#executables

login-server: obj $(LOGIN_DIR_OBJ) $(CUSTOM_DIR_OBJ) $(COMMON_AR) $(RAPIDYAML_AR)
	@echo "	LD	@OLOG@@EXEEXT@"
	@@CXX@ @LDFLAGS@ -o ../../@OLOG@@EXEEXT@ $(LOGIN_DIR_OBJ) $(CUSTOM_DIR_OBJ) $(COMMON_AR) $(LIBCONFIG_AR) $(RAPIDYAML_AR) @LIBS@ @MYSQL_LIBS@

# login object files

obj/%.o: %.cpp $(LOGIN_H) $(COMMON_H) $(LIBCONFIG_H) $(RAPIDYAML_H)
	@echo "	CXX	$<"
	@@CXX@ @CXXFLAGS@ $(CUSTOM_INCLUDE) $(CUSTOM_DEFINES) $(COMMON_INCLUDE) $(RA_INCLUDE) $(LIBCONFIG_INCLUDE) $(RAPIDYAML_INCLUDE) -DWITH_SQL @MYSQL_CFLAGS@ @CPPFLAGS@ -c $(OUTPUT_OPTION) $<

# SATHENA: compile rule for external consumer sources (see CUSTOM_SRC_DIR above)
obj/custom/%.o: $(CUSTOM_SRC_DIR)/%.cpp $(COMMON_H)
	@echo "	CXX	$<"
	@-mkdir -p $(dir $@)
	@@CXX@ @CXXFLAGS@ $(CUSTOM_INCLUDE) $(CUSTOM_DEFINES) $(COMMON_INCLUDE) $(RA_INCLUDE) $(LIBCONFIG_INCLUDE) $(RAPIDYAML_INCLUDE) -DWITH_SQL @MYSQL_CFLAGS@ @CPPFLAGS@ -c $(OUTPUT_OPTION) $<

# missing object files
$(COMMON_AR):
	@$(MAKE) -C ../common server

$(LIBCONFIG_AR):
	@$(MAKE) -C ../../3rdparty/libconfig

$(RAPIDYAML_AR):
	@$(MAKE) -C ../../3rdparty/rapidyaml
